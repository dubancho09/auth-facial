# App
APP_HOST=0.0.0.0
APP_PORT=5000
FLASK_DEBUG=0
SECRET_KEY=change-this-in-production
MAX_CONTENT_LENGTH=4194304
SECURITY_HEADERS_ENABLED=1

# Database
DB_ENGINE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ocr
DB_USER=ocr_user
DB_PASSWORD=ocr_password

# Optional: direct SQLAlchemy URL (takes precedence over DB_* vars)
# DATABASE_URL=postgresql+psycopg2://ocr_user:ocr_password@localhost:5432/ocr

# Plugin security
PLUGIN_SECURITY_ENABLED=1
PLUGIN_TOKEN_TTL_SECONDS=120
# Format: client_id:api_key,client_id2:api_key2
PLUGIN_CLIENTS=erp_portal:erp-secret-key
# Optional allowlist of frontends allowed in plugin tokens
PLUGIN_ALLOWED_ORIGINS=https://tu-app.com,http://localhost:3000

# Optional protection for registration endpoint
# REGISTER_API_KEY=register-admin-key

# Rate limit
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_TOKEN_PER_WINDOW=20
RATE_LIMIT_REGISTER_PER_WINDOW=10
RATE_LIMIT_AUTH_PER_WINDOW=180

# Registration anti-duplicate by biometric similarity
DUPLICATE_FACE_THRESHOLD=0.92
